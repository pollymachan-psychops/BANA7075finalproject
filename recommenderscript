from pathlib import Path
import joblib
import pandas as pd

BASE_DIR = Path(__file__).resolve().parent.parent
MODEL_DIR = BASE_DIR / "models"

PATIENT_TEXT_COLS = [
    "primary_diagnosis",
    "priority_1",
    "priority_2",
    "transition_focus",
    "coordinator_comfort",
]

PROGRAM_TEXT_COLS = [
    "program_name",
    "location",
    "length_of_stay",
    "treatment_specialty",
    "levels_of_care",
    "insurance_cost",
    "acuity_level",
    "primary_population",
    "program_type",
    "cost_tier",
    "independence_focus",
]

FEATURE_COLS = [
    "age",
    "primary_diagnosis",
    "priority_1",
    "priority_2",
    "transition_focus",
    "coordinator_comfort",
    "location",
    "length_of_stay",
    "treatment_specialty",
    "levels_of_care",
    "insurance_cost",
    "acuity_level",
    "primary_population",
    "program_type",
    "continuum_score",
    "cost_tier",
    "independence_focus",
    "diagnosis_match",
    "focus_match",
    "priority1_population_match",
    "priority2_population_match",
    "comfort_acuity_match",
]


def normalize_text(value):
    if pd.isna(value):
        return "unknown"
    return str(value).strip().lower()


def load_artifacts():
    model_path = MODEL_DIR / "patient_program_rf.joblib"
    program_path = MODEL_DIR / "program_reference.csv"

    if not model_path.exists():
        raise FileNotFoundError(f"Model file not found: {model_path}")
    if not program_path.exists():
        raise FileNotFoundError(f"Program reference file not found: {program_path}")

    pipeline = joblib.load(model_path)
    program_df = pd.read_csv(program_path)

    for col in PROGRAM_TEXT_COLS:
        if col in program_df.columns:
            program_df[col] = program_df[col].apply(normalize_text)

    return pipeline, program_df


def prepare_patient_df(patient_input: dict) -> pd.DataFrame:
    df = pd.DataFrame([patient_input])

    for col in PATIENT_TEXT_COLS:
        if col in df.columns:
            df[col] = df[col].apply(normalize_text)

    return df


def _score_patient_program_pairs(patient_input: dict, pipeline, program_df: pd.DataFrame) -> pd.DataFrame:
    patient_df = prepare_patient_df(patient_input)

    patient_rows = patient_df.copy()
    patient_rows["join_key"] = 1

    program_rows = program_df.copy()
    program_rows["join_key"] = 1

    scored_pairs = patient_rows.merge(program_rows, on="join_key").drop(columns=["join_key"])

    scored_pairs["diagnosis_match"] = (
        scored_pairs["primary_diagnosis"] == scored_pairs["treatment_specialty"]
    ).astype(int)

    scored_pairs["focus_match"] = (
        scored_pairs["transition_focus"] == scored_pairs["independence_focus"]
    ).astype(int)

    scored_pairs["priority1_population_match"] = (
        scored_pairs["priority_1"] == scored_pairs["primary_population"]
    ).astype(int)

    scored_pairs["priority2_population_match"] = (
        scored_pairs["priority_2"] == scored_pairs["primary_population"]
    ).astype(int)

    scored_pairs["comfort_acuity_match"] = (
        scored_pairs["coordinator_comfort"] == scored_pairs["acuity_level"]
    ).astype(int)

    scored_pairs["predicted_match_probability"] = pipeline.predict_proba(
        scored_pairs[FEATURE_COLS]
    )[:, 1]

    return scored_pairs


def recommend_programs(patient_input: dict, pipeline, program_df: pd.DataFrame, top_n: int = 3):
    scored_pairs = _score_patient_program_pairs(patient_input, pipeline, program_df)

    top_recommendations = (
        scored_pairs
        .sort_values("predicted_match_probability", ascending=False)
        .drop_duplicates(subset=["program_name"])
        .head(top_n)[[
            "program_name",
            "location",
            "program_type",
            "primary_population",
            "predicted_match_probability",
        ]]
        .reset_index(drop=True)
    )

    top_max = top_recommendations["predicted_match_probability"].max()

    if pd.notna(top_max) and top_max > 0:
        top_recommendations["display_confidence"] = (
            top_recommendations["predicted_match_probability"] / top_max
        )
    else:
        fallback = [1.0, 0.8, 0.6][:len(top_recommendations)]
        top_recommendations["display_confidence"] = fallback

    results = []
    for _, row in top_recommendations.iterrows():
        results.append({
            "program": row["program_name"],
            "location": row["location"],
            "program_type": row["program_type"],
            "primary_population": row["primary_population"],
            "confidence": float(row["display_confidence"]),
            "raw_score": float(row["predicted_match_probability"]),
        })

    return results


def recommend_programs_batch(records: list[dict], pipeline, program_df: pd.DataFrame, top_n: int = 3):
    batch_results = []

    for idx, record in enumerate(records, start=1):
        recs = recommend_programs(
            patient_input=record,
            pipeline=pipeline,
            program_df=program_df,
            top_n=top_n,
        )
        batch_results.append({
            "record_id": idx,
            "input": record,
            "recommendations": recs,
        })

    return batch_results
